local Player = game:GetService("Players").LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

if PlayerGui:FindFirstChild("StandardSpammer") then
	PlayerGui.StandardSpammer:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "StandardSpammer"
ScreenGui.Parent = PlayerGui
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame")
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -100)
MainFrame.Size = UDim2.new(0, 200, 0, 190)
MainFrame.Active = true
MainFrame.Draggable = true

local Title = Instance.new("TextLabel")
Title.Parent = MainFrame
Title.Size = UDim2.new(1, 0, 0, 30)
Title.Text = "Item Spammer"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.BackgroundTransparency = 1

local ArgsInput = Instance.new("TextBox")
ArgsInput.Parent = MainFrame
ArgsInput.Position = UDim2.new(0.1, 0, 0.2, 0)
ArgsInput.Size = UDim2.new(0.8, 0, 0, 30)
ArgsInput.Text = "Lolly Yellow"
ArgsInput.PlaceholderText = "Enter Name..."
ArgsInput.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
ArgsInput.TextColor3 = Color3.fromRGB(255, 255, 255)

local DelayInput = Instance.new("TextBox")
DelayInput.Parent = MainFrame
DelayInput.Position = UDim2.new(0.1, 0, 0.4, 0)
DelayInput.Size = UDim2.new(0.8, 0, 0, 30)
DelayInput.Text = "1"
DelayInput.PlaceholderText = "Delay (seconds)..."
DelayInput.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
DelayInput.TextColor3 = Color3.fromRGB(255, 255, 255)

local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Parent = MainFrame
ToggleBtn.Position = UDim2.new(0.1, 0, 0.65, 0)
ToggleBtn.Size = UDim2.new(0.8, 0, 0, 40)
ToggleBtn.Text = "Status: OFF"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

local active = false
local EquipRemote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("Equip")
local DropRemote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("Drop")

ToggleBtn.MouseButton1Click:Connect(function()
	active = not active
	if active then
		ToggleBtn.Text = "Status: ON"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		task.spawn(function()
			while active do
				local itemName = ArgsInput.Text
				local delayTime = tonumber(DelayInput.Text) or 0
				EquipRemote:FireServer(itemName)
				DropRemote:FireServer(itemName)
				task.wait(delayTime)
			end
		end)
	else
		ToggleBtn.Text = "Status: OFF"
		ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	end
end)

ToggleBtn.MouseButton1Click:Connect(function()
    active = not active
    if active then
        ToggleBtn.Text = "STOPPING..."
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        ToggleBtn.Text = "STOP"
        
        -- High-speed loop
        task.spawn(function()
            while active do
                local itemName = ArgsInput.Text
                EquipRemote:FireServer(itemName)
                DropRemote:FireServer(itemName)
                -- task.wait() is used to prevent the executor from hanging
                task.wait() 
            end
        end)
    else
        ToggleBtn.Text = "START"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    end
end)

-- Hide/Show UI with Left Control
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.LeftControl then
        MainFrame.Visible = not MainFrame.Visible
    end
end)
